# Copy this file to .env before running.
# Use either a raw cookie string copied from browser, OR split variables.

# Recommended: raw cookie string from https://meta.ai browser session
META_COOKIE_STRING=datr=...; ecto_1_sess=...; wd=1256x919; dpr=1; rd_challenge=...

# Optional split variables if you do not want to use META_COOKIE_STRING
META_AI_DATR=
META_AI_ECTO_1_SESS=
META_AI_WD=1256x919
META_AI_DPR=1
META_AI_RD_CHALLENGE=

# Runtime options
TZ=Asia/Bangkok
META_DOWNLOAD_DIR=/app/downloads
META_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36
META_ACCEPT_LANGUAGE=vi-VN,vi;q=0.9,fr-FR;q=0.8,fr;q=0.7,en-US;q=0.6,en;q=0.5
